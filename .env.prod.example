# PostgreSQL Database Credentials
DB_USER=lab_user
DB_PASSWORD=lab_password_2026
DB_NAME=lab_logs

# Authentication Secrets
# IMPORTANT: Generate a secure 32-byte secret key on the server:
# Command to generate: openssl rand -hex 32
SECRET_KEY=yoursecurerandomsecretkeyforjwttokenencoding2026prod

# JWT Expiration time (1440 minutes = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
