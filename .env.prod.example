# ==============================================================================
# MUX — Production Environment Configuration
# Copy this file to .env.prod and update values before deployment.
# ==============================================================================

# PostgreSQL bootstrap/owner credentials. These are used by mux-db and the
# one-shot migrator only; never injected into mux-app or mux-scheduler.
DB_USER=mux_prod_admin
DB_PASSWORD=your_secure_password_here
DB_NAME=mux_lab_logs

# Least-privilege runtime accounts. deploy.sh generates passwords if omitted.
APP_DB_USER=mux_app
APP_DB_PASSWORD=change-me-to-a-random-app-db-password
BACKUP_DB_USER=mux_backup
BACKUP_DB_PASSWORD=change-me-to-a-random-backup-db-password

# JWT Authentication Secret (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-32-byte-hex-string

# Short-lived access session in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Encrypt backups at rest. Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=change-me-to-a-random-backup-encryption-key

# Set true only during an approved, offline restore window.
MAINTENANCE_MODE=false

# Application port on the host
APP_PORT=18080
APP_BIND_ADDRESS=127.0.0.1

# Set true only behind an HTTPS/TLS reverse proxy with an HTTPS CORS origin.
# The false default is intentionally limited to local HTTP development.
COOKIE_SECURE=false

# Existing production volume. Keep this value when upgrading from the
# previous four-container deployment so the database is reused.
DB_VOLUME_NAME=physics-lab-log_postgres_prod_data

# Optional build proxy for apt/npm/pip inside Docker build steps
# BUILD_HTTP_PROXY=http://host.docker.internal:1082
# BUILD_HTTPS_PROXY=http://host.docker.internal:1082
# BUILD_NO_PROXY=localhost,127.0.0.1,mux-db
