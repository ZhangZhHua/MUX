# ==============================================================================
# MUX Lab Log — Production Environment Template
# Copy to .env.prod and fill in your values
# ==============================================================================

# Application port (external)
APP_PORT=18080

# PostgreSQL credentials
DB_USER=lab_user
DB_PASSWORD=lab_password_2026
DB_NAME=lab_logs

# JWT signing secret (generate with: openssl rand -hex 32)
SECRET_KEY=yoursecurerandomsecretkeyforjwttokenencoding2026prod

# Session timeout in minutes (1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440
