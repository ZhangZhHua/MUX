# ==============================================================================
# MUX — Production Environment Configuration
# Copy this file to .env.prod and update values before deployment.
# ==============================================================================

# PostgreSQL Database Credentials
DB_USER=mux_prod_admin
DB_PASSWORD=your_secure_password_here
DB_NAME=mux_lab_logs

# JWT Authentication Secret (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-32-byte-hex-string

# Session timeout in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Application port on the host
APP_PORT=18080

# Existing production volume. Keep this value when upgrading from the
# previous four-container deployment so the database is reused.
DB_VOLUME_NAME=physics-lab-log_postgres_prod_data

# Optional build proxy for apt/npm/pip inside Docker build steps
# BUILD_HTTP_PROXY=http://host.docker.internal:1082
# BUILD_HTTPS_PROXY=http://host.docker.internal:1082
# BUILD_NO_PROXY=localhost,127.0.0.1,mux-db
